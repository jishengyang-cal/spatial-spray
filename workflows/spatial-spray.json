{
  "version": 1,
  "name": "spatial-spray",
  "hardBoundary": "Native iOS and visionOS build, signing, official simulator, device install, TestFlight, and App Store submission require macOS, Xcode, Apple SDKs, signing assets, and Apple-controlled credentials.",
  "phases": [
    {
      "id": "contracts",
      "title": "Shared contracts and brush model",
      "capabilities": ["linux-runnable"],
      "command": "pnpm build:packages",
      "produces": ["auth contracts", "spray piece model", "brush particle engine"]
    },
    {
      "id": "api",
      "title": "Persistent API and moderation control plane",
      "capabilities": ["linux-runnable"],
      "command": "pnpm test:api",
      "produces": ["dev/provider login boundary", "refresh session", "unique username", "nearby query", "map clusters", "spray creation", "report/block", "admin moderation", "location denylist", "audit log"]
    },
    {
      "id": "web-simulator",
      "title": "Map and camera simulator",
      "capabilities": ["linux-runnable"],
      "command": "pnpm test:e2e",
      "produces": ["login flow", "username flow", "spray canvas", "nearby map"]
    },
    {
      "id": "native-ios",
      "title": "iPhone AR client",
      "capabilities": ["mac-builder-required", "device-required"],
      "command": "pnpm native:ios-build:submit",
      "produces": ["MapKit nearby discovery", "ARKit camera spray capture", "RealityKit preview paint", "spray publish"]
    },
    {
      "id": "native-visionos",
      "title": "Apple Vision Pro client",
      "capabilities": ["mac-builder-required", "device-required"],
      "command": "pnpm native:visionos-build:submit",
      "produces": ["SwiftUI nearby discovery", "RealityKit mixed immersive spray view", "nearby spray panel"]
    },
    {
      "id": "mac-builder",
      "title": "Remote Mac Builder adapter",
      "capabilities": ["linux-runnable", "mac-builder-required", "mcp-candidate"],
      "command": "pnpm native:mac-builder:check",
      "produces": ["builder capability check", "mock worker", "build job request", "job polling", "artifact/log refs"]
    },
    {
      "id": "release-compliance",
      "title": "Store and UGC compliance",
      "capabilities": ["apple-account-required"],
      "command": "pnpm compliance:check",
      "produces": ["sign-in boundary", "UGC controls", "location privacy", "native toolchain boundary", "privacy/content/review drafts"]
    },
    {
      "id": "ci",
      "title": "Linux CI and native boundary guard",
      "capabilities": ["linux-runnable"],
      "command": "pnpm workflow:check && pnpm test",
      "produces": ["typecheck", "build", "API e2e", "web e2e", "Mac Builder capability check"]
    }
  ]
}
